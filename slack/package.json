{
  "name": "slack",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "ncc build index.js -o dist --minify",
    "pretest": "npm run build && git diff --exit-code -- dist",
    "test": "jest --coverage"
  },
  "jest": {
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 100,
        "lines": 90,
        "statements": 90
      }
    }
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@actions/core": "^2.0.3",
    "axios": "^1.16.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.4",
    "jest": "^30.2.0"
  }
}
